// The first bit of text (that isn't a comment or whitespace) should be the Theatre name and index
// While it's not a requirement, it's a strong recommendation
@HelloWorldTheatre#0

// All definitions are contained in one or both "contexts". These contexts don't serve any functional purpose, and are simply a way
// of keeping the file format clean, distinct, and separated. However, I may make contexts not a requirement in the future
Resources
{
    // Definitions are done like a mixture of a C/C++ variable and struct
    // They start with a "typename", followed by the object's name, followed by a pair of curly braces
    // Whitespace is allowed around the curly braces for formatting purposes
    // Inside a definition are variable definitions. These are Python-esque, being terminated by a newline
    Mesh Cube_Mesh
    {
        // This is a String, delimited by sinqle-quotes. Strings capture everything inside them, including whitespace
        File = 'src/testing_app/resources/Cube.obj'
    }

    Mesh Ramiel_Mesh
    {
        // This is an Engine reference, delimited by square braces. It is the name of a special engine variable
        // (in the future, your game/app can define its own "Engine" references which your Theatre files can use)
        Data = [RamielModel]
    }

    Texture Doom_Texture
    {
        Data = [DoomTexture]
    }

    Material Cube_Mat
    {
        // This is a Theatre reference, delimited by angled braces. It is the name of another object defined in this Theatre file
        DiffuseTexture = <Doom_Texture>
    }

    Material Ramiel_Mat
    {
        // This is a boolean Numeric variable; see lines 55-56 for more information
        NoTexture = (True)
    }

    MeshInstance RamielMeshInstance
    {
        Mesh = <Ramiel_Mesh>
        Material = <Ramiel_Mat>
    }
}

Things
{
    Actor TestActor
    {
        MeshInstance = <RamielMeshInstance>
        // These are Numeric variables, delimited by parentheses. They can be one or more numbers, or a boolean (true/false)
        // Numbers can be whole, decimal, positive, and negative; multiple numbers must be separated by commas
        Origin = (-3, 1.0, -2) // An example of all the different number types working together!
        IsVisible = (True) // Booleans are not case-sensitive (example on line 76)
    }

    Actor TestActor2
    {
        // This is a sandwich. It's a way of defining an object inside another object, for convenience
        // Internally, they are converted into a separate definition, and the variable value is replaced
        // with a Theatre reference to that new object
        // They begin with the variable name, followed by a colon instead of an equals sign, and then a typical
        // object definition afterwards
        // They are great for when you don't want to define a new object and manually reference it, like in this example:
        MeshInstance : MeshInstance CubeMeshInstance
        {
            Mesh = <Cube_Mesh>
            Material = <Cube_Mat>
        }
        Origin = (3, 0, -3)
        Rotation = (-0.1, 0, 0.1)
        IsVisible = (trUe) // An example of boolean case-insensitivity
    }

    PointLight Light
    {
        Origin = (0, 1, -1.5)
        Color  = (0.82, 0.75, 1.0)
        Visible = (false) // I'll introduce a default debug Light mesh in an upcoming commit
    }

    DirectionalLight Sun
    {
        RotationDegrees = (-70, 25, 0)
        Visible = (false)
    }

    NostalgiaPlayer Player
    {
        Origin = (0, 1, 3)
    }
}
